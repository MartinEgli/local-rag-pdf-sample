{
  "name": "local-rag-pdf-sample",
  "version": "0.8.0",
  "private": true,
  "description": "End-to-end PDF ingestion and MCP retrieval sample for the local-rag skill.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "extract": "node scripts/extract-pdfs.mjs",
    "rag:build": "node scripts/runtime-cli.mjs build",
    "rag:query": "node scripts/runtime-cli.mjs query",
    "rag:smoke": "node scripts/mcp-smoke-test.mjs",
    "rag:kag:smoke": "node scripts/kag-smoke-test.mjs",
    "rag:pdf:integration": "node scripts/runtime-pdf-ingest-test.mjs",
    "mcp:configs": "node scripts/generate-mcp-configs.mjs",
    "mcp:configs:test": "node scripts/mcp-config-integration-test.mjs",
    "perf": "node scripts/run-performance.mjs",
    "portable:test": "node scripts/portable-bundle-test.mjs",
    "visual:test": "node scripts/visual-description-test.mjs",
    "test": "npm run extract && node --test tests/*.test.mjs && npm run rag:pdf:integration && npm run mcp:configs:test && npm run rag:smoke && npm run portable:test && npm run visual:test"
  },
  "dependencies": {
    "pdfjs-dist": "6.1.200"
  },
  "engines": {
    "node": ">=22.13.0 || >=24"
  }
}
